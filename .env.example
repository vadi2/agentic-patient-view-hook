# This service authenticates to Claude via your local `claude` CLI login -
# the Agent SDK shells out to the installed binary. Run `claude login` once;
# no API key is needed here. ANTHROPIC_API_KEY is still honoured by the SDK
# if you'd rather use a raw key.

# Optional overrides
PORT=3000
CLAUDE_MODEL=claude-sonnet-4-6

# Absolute base URL used to build the card's source.icon link.
# Defaults to http://localhost:${PORT} when unset.
PUBLIC_BASE_URL=http://localhost:3000
